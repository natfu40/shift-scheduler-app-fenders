# =============================================================
# Shift Scheduler - Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================

# ── Database ─────────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=your_secure_db_password
DB_NAME=shift_scheduler
DB_PORT=5432

# ── JWT ──────────────────────────────────────────────────────
# Generate a strong secret (at least 32 chars)
JWT_SECRET=your-very-secure-jwt-secret-key-at-least-32-characters-long
JWT_EXPIRATION=86400000

# ── Backend ──────────────────────────────────────────────────
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=dev
JPA_DDL_AUTO=update

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_PORT=3000
# URL the browser uses to reach the API
# Dev:  http://localhost:8080
# Prod: https://yourdomain.com
REACT_APP_API_URL=http://localhost:8080

# ── Production only ──────────────────────────────────────────
PORT=80
